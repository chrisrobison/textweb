{
  "name": "textweb",
  "description": "Text-grid web browser for AI agents. Renders pages as structured text with interactive element references instead of screenshots.",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "textweb_navigate",
        "description": "Navigate to a URL and render the page as a structured text grid.",
        "parameters": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "The URL to navigate to"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "url"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_click",
        "description": "Click an interactive element identified by its [ref] number.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number (e.g., 3 for [3])"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_type",
        "description": "Type text into an input field identified by its [ref] number.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number of the input field"
            },
            "text": {
              "type": "string",
              "description": "Text to enter into the field"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref",
            "text"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_select",
        "description": "Select an option from a dropdown by its [ref] number.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number of the dropdown"
            },
            "value": {
              "type": "string",
              "description": "Option value or visible text to select"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref",
            "value"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_upload",
        "description": "Upload a file to a file input element.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number of the file input"
            },
            "path": {
              "type": "string",
              "description": "Absolute file path to upload"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "ref",
            "path"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_press",
        "description": "Press a keyboard key (Enter, Tab, Escape, ArrowDown, etc.).",
        "parameters": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string",
              "description": "Key name (e.g., Enter, Tab, Escape)"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            }
          },
          "required": [
            "key"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_scroll",
        "description": "Scroll the current page.",
        "parameters": {
          "type": "object",
          "properties": {
            "direction": {
              "type": "string",
              "enum": [
                "up",
                "down",
                "top"
              ],
              "description": "Scroll direction"
            },
            "amount": {
              "type": "integer",
              "description": "Pages to scroll (default: 1)",
              "default": 1
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "direction"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_snapshot",
        "description": "Re-render the current page without navigating.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_storage_save",
        "description": "Save cookies/localStorage/sessionStorage to a storageState JSON file.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute output path for storage state JSON"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "path"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_storage_load",
        "description": "Load cookies/localStorage/sessionStorage from a storageState JSON file.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute storage state path"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "path"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_wait_for",
        "description": "Wait for selector/text/url state during multi-step flows.",
        "parameters": {
          "type": "object",
          "properties": {
            "selector": {
              "type": "string",
              "description": "CSS selector to wait for"
            },
            "text": {
              "type": "string",
              "description": "Page text to wait for"
            },
            "url_includes": {
              "type": "string",
              "description": "Substring expected in URL"
            },
            "state": {
              "type": "string",
              "enum": [
                "attached",
                "detached",
                "visible",
                "hidden"
              ],
              "description": "Selector state"
            },
            "timeout_ms": {
              "type": "integer",
              "description": "Timeout milliseconds"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            },
            "retries": {
              "type": "integer",
              "description": "Retry attempts for flaky transitions"
            },
            "retry_delay_ms": {
              "type": "integer",
              "description": "Delay between retries in ms"
            },
            "poll_ms": {
              "type": "integer",
              "description": "Polling interval for text/url waits"
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_assert_field",
        "description": "Assert field value/text by element ref.",
        "parameters": {
          "type": "object",
          "properties": {
            "ref": {
              "type": "integer",
              "description": "Element reference number"
            },
            "expected": {
              "type": "string",
              "description": "Expected value or content"
            },
            "comparator": {
              "type": "string",
              "enum": [
                "equals",
                "includes",
                "regex",
                "not_empty"
              ],
              "description": "Comparison mode"
            },
            "attribute": {
              "type": "string",
              "description": "Optional attribute to assert"
            },
            "session_id": {
              "type": "string",
              "description": "Optional session id (default: default)"
            }
          },
          "required": [
            "ref",
            "expected"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_session_list",
        "description": "List active textweb sessions and metadata.",
        "parameters": {
          "type": "object",
          "properties": {}
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "textweb_session_close",
        "description": "Close one session by session_id, or all sessions when all=true.",
        "parameters": {
          "type": "object",
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Session id to close (default: default)"
            },
            "all": {
              "type": "boolean",
              "description": "Close all active sessions"
            }
          }
        }
      }
    }
  ]
}